# ══════════════════════════════════════════════════════════════
# ⚠️  SEGURANÇA: TODAS as variáveis abaixo são OBRIGATÓRIAS
# O sistema NÃO funciona sem elas configuradas.
# NÃO use os valores de exemplo — gere senhas fortes!
# ══════════════════════════════════════════════════════════════

# Credenciais do Painel Administrativo (mínimo 16 caracteres, com letras, números e símbolos)
ADMIN_EMAIL=admin@draandresa.com
ADMIN_PASSWORD=

# Credenciais da Secretária
SECRETARY_EMAIL=secretaria@draandresa.com
SECRETARY_PASSWORD=

# Chave secreta para JWT — OBRIGATÓRIO!
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# URL do site
NEXT_PUBLIC_SITE_URL=https://draandrezamartinsobstetra.vercel.app

# Google Places API (para reviews em tempo real)
# 1. Acesse https://console.cloud.google.com
# 2. Ative a "Places API"
# 3. Crie uma API Key
GOOGLE_PLACES_API_KEY=
# Para encontrar o Place ID: https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACE_ID=

# Prontmed - Integração com sistema de prontuário
# Configure caso utilize o sistema Prontmed
PRONTMED_API_URL=https://api.prontmed.com/v1
PRONTMED_API_KEY=
PRONTMED_CLINIC_ID=
